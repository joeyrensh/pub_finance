{
  "description": "中国大陆代理源配置",
  "sources": {
    "zdaye": {
      "name": "站大爷",
      "url": "https://www.zdaye.com/free/",
      "type": "browser",
      "params": {
        "max_pages": 3,
        "dengji": 3
      },
      "enabled": true
    },
    "openproxylist": {
      "name": "OpenProxyList",
      "url": "https://api.openproxylist.xyz/http.txt",
      "type": "requests",
      "enabled": true
    },
    "geonode": {
      "name": "Geonode",
      "url": "https://proxylist.geonode.com/api/proxy-list",
      "type": "requests",
      "params": {
        "limit": 500
      },
      "enabled": true
    }
  },
  "github_sources": [
    {
      "name": "TheSpeedX-HTTP",
      "url": "https://raw.githubusercontent.com/TheSpeedX/PROXY-List/master/http.txt",
      "protocol": "http",
      "enabled": true
    },
    {
      "name": "monosans-HTTP",
      "url": "https://raw.githubusercontent.com/monosans/proxy-list/main/proxies/http.txt",
      "protocol": "http",
      "enabled": true
    },
    {
      "name": "ShiftyTR-HTTP",
      "url": "https://raw.githubusercontent.com/ShiftyTR/Proxy-List/master/http.txt",
      "protocol": "http",
      "enabled": true
    }
  ],
  "validation": {
    "test_url": "http://www.baidu.com",
    "china_first_octets": [1, 14, 18, 21, 27, 31, 36, 39, 42, 49, 58, 59, 60, 61, 62, 63, 101, 102, 106, 110, 111, 112, 113, 114, 115, 116, 117, 118, 119, 120, 121, 122, 123, 124, 125, 126, 127, 140, 144, 150, 153, 163, 171, 172, 173, 174, 175, 180, 181, 182, 183, 187, 189, 202, 210, 211, 218, 219, 220, 221, 222, 223],
    "timeout": 3,
    "max_workers": 20
  },
  "maintenance": {
    "max_failures": 3,
    "proxies_file": "china_proxies.txt",
    "proxies_json": "china_proxies.json"
  }
}
