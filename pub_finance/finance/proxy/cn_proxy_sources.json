{
  "description": "中国大陆代理源配置（requests 版 - 无需 agent-browser）",
  "sources": {
    "zdaye": {
      "name": "站大爷",
      "url": "https://www.zdaye.com/free/",
      "type": "requests",
      "params": {
        "max_pages": 3,
        "dengji": 3
      },
      "enabled": true
    },
    "openproxylist": {
      "name": "OpenProxyList",
      "url": "https://api.openproxylist.xyz/http.txt",
      "type": "requests",
      "enabled": true
    },
    "geonode": {
      "name": "Geonode",
      "url": "https://proxylist.geonode.com/api/proxy-list",
      "type": "requests",
      "params": {
        "limit": 500
      },
      "enabled": true
    },
    "proxifly": {
      "name": "Proxifly-GitHub",
      "url": "https://raw.githubusercontent.com/proxifly/free-proxy-list/main/proxies/all/data.txt",
      "type": "requests",
      "enabled": true,
      "note": "✅ GitHub 仓库，约 8000+ 代理"
    }
  },
  "github_sources": [],
  "validation": {
    "test_url": "http://www.baidu.com",
    "timeout": 3,
    "max_workers": 20
  },
  "maintenance": {
    "max_failures": 3,
    "proxies_file": "china_proxies.txt",
    "proxies_json": "china_proxies.json"
  }
}
